# .env — Généré par Ansible, ne pas éditer manuellement
# ======================================================
# Ce fichier est injecté dans les containers via env_file dans docker-compose.

DOMAIN_NAME={{ domain_name }}

# MariaDB
SQL_DATABASE={{ db_name }}
SQL_ROOT_PASSWORD={{ vault_db_root_password }}
SQL_USER={{ db_user }}
SQL_PASSWORD={{ vault_db_password }}

# WordPress
WP_URL=https://{{ domain_name }}
WP_TITLE={{ wp_title }}
WP_ADMIN_USER={{ wp_admin_user }}
WP_ADMIN_PASSWORD={{ vault_wp_admin_password }}
WP_ADMIN_EMAIL={{ wp_admin_email }}
