-- init.sql — Généré par Ansible, ne pas éditer manuellement
-- ============================================================

CREATE DATABASE IF NOT EXISTS {{ db_name }};
CREATE USER IF NOT EXISTS '{{ db_user }}'@'%' IDENTIFIED BY '{{ vault_db_password }}';
GRANT ALL PRIVILEGES ON {{ db_name }}.* TO '{{ db_user }}'@'%';

-- Sécuriser le compte root
ALTER USER 'root'@'localhost' IDENTIFIED BY '{{ vault_db_root_password }}';

FLUSH PRIVILEGES;
